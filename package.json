{
  "name": "cloud-health",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/IIawaII/cloud-health"
  },
  "bugs": {
    "url": "https://github.com/IIawaII/cloud-health/issues"
  },
  "homepage": "https://github.com/IIawaII/cloud-health#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "wrangler dev --config wrangler.dev.toml",
    "build": "node scripts/build-avatar-sprite.mjs && vite build --config configs/vite.config.ts && node scripts/generate-spa-fallback.cjs",
    "build:check": "tsc -b",
    "deploy": "wrangler deploy",
    "lint": "eslint . -c configs/eslint.config.js",
    "test": "vitest run --config configs/vitest.config.ts && playwright test --config configs/playwright.config.cjs",
    "test:unit": "vitest run --config configs/vitest.config.ts",
    "test:e2e": "playwright test --config configs/playwright.config.cjs",
    "test:watch": "vitest --config configs/vitest.config.ts",
    "db:generate": "drizzle-kit generate --config configs/drizzle.config.ts",
    "db:push": "drizzle-kit push --config configs/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config configs/drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply cloud-health-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cloud-health-db --remote",
    "password": "node scripts/hash-password.mjs"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swagger-ui-dist": "^5.32.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.0",
    "wrangler": "^4.87.0"
  }
}
